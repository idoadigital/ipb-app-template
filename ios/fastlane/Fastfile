default_platform(:ios)

platform :ios do
  desc "Build the iOS app"
  lane :build do
    setup_ci

    # Import signing certificate and provisioning profile from environment
    # These are set as GitHub Actions secrets
    api_key = app_store_connect_api_key(
      key_id: ENV["ASC_KEY_ID"],
      issuer_id: ENV["ASC_ISSUER_ID"],
      key_content: ENV["ASC_KEY_CONTENT"],
      is_key_content_base64: true,
      duration: 1200,
    )

    # Match or manual signing
    match(
      type: "appstore",
      app_identifier: ENV["IOS_BUNDLE_ID"],
      api_key: api_key,
      readonly: true,
    )

    build_app(
      workspace: "App.xcworkspace",
      scheme: ENV["APP_NAME"] || "App",
      export_method: "app-store",
      output_directory: "./build",
      output_name: "app.ipa",
      clean: true,
      export_options: {
        provisioningProfiles: {
          ENV["IOS_BUNDLE_ID"] => ENV["PROVISIONING_PROFILE_NAME"] || "match AppStore #{ENV['IOS_BUNDLE_ID']}"
        }
      }
    )
  end

  desc "Upload to TestFlight"
  lane :upload_to_testflight_lane do
    api_key = app_store_connect_api_key(
      key_id: ENV["ASC_KEY_ID"],
      issuer_id: ENV["ASC_ISSUER_ID"],
      key_content: ENV["ASC_KEY_CONTENT"],
      is_key_content_base64: true,
      duration: 1200,
    )

    upload_to_testflight(
      api_key: api_key,
      ipa: "./build/app.ipa",
      skip_waiting_for_build_processing: true,
      skip_submission: false,
      distribute_external: false,
    )
  end
end
